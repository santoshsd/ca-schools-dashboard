# CA School Dashboard — Environment Variables
# Copy this file to .env and fill in the values.
#
# On Railway, set these in your service's Variables tab.
# On Docker, pass them via docker run --env-file or docker-compose.yml.

# ─── Required ───────────────────────────────────────────────────────

# PostgreSQL connection string.
# Railway: use the DATABASE_URL from the PostgreSQL plugin (auto-provisioned)
# Local:   postgresql://postgres:postgres@localhost:5432/cadashboard
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cadashboard

# Express session signing key. Must be at least 32 characters.
# Generate one:  openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# ─── Optional ───────────────────────────────────────────────────────

# Server port. Railway assigns PORT automatically; local dev uses 5000.
PORT=8080

# Node environment.
NODE_ENV=production

# Comma-separated list of allowed CORS origins for the dashboard.
# Leave empty to allow all origins (development convenience).
# Example: https://cadashboard.s13i.me,https://caschooldatahub.s13i.me
CORS_ALLOWED_ORIGINS=
